{
  "schema_version": "domain_pack.v1",
  "id": "hardware.verification",
  "name": "Hardware Verification & Coverage",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "hw_verification",
    "uvm",
    "formal",
    "coverage",
    "assertion"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "hardware.hdl",
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['hw_verification','uvm','formal','coverage','assertion'].includes(d)) || profile.repo_signals.some(s=>/\\b(uvm|universal verification|constrained.?random|functional coverage|formal verification|assertion.?based|covergroup|coverpoint|questa|\\bvcs\\b)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
