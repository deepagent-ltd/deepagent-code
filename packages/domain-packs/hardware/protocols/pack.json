{
  "schema_version": "domain_pack.v1",
  "id": "hardware.protocols",
  "name": "Hardware Serial & Bus Protocols",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "hw_protocols",
    "i2c",
    "spi",
    "uart",
    "can",
    "usb",
    "pcie"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.embedded",
    "code.systems"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['hw_protocols','i2c','spi','uart','can','usb','pcie'].includes(d)) || profile.repo_signals.some(s=>/\\b(i2c|spi bus|uart|can bus|usb descriptor|pcie lane|serial protocol|bit.?bang|clock stretching|device address)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
