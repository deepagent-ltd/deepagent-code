{
  "schema_version": "domain_pack.v1",
  "id": "hardware.hdl",
  "name": "Hardware Description Languages (Verilog/SystemVerilog/VHDL)",
  "description": "硬件描述语言:Verilog/SystemVerilog/VHDL 的 RTL 开发",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "hdl",
    "verilog",
    "systemverilog",
    "vhdl",
    "rtl",
    "fpga"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['hdl','verilog','systemverilog','vhdl','rtl','fpga'].includes(d)) || profile.repo_signals.some(s=>/\\b(verilog|systemverilog|vhdl|always_ff|always_comb|testbench|rtl|fpga|synthesi[sz]|timing closure|clock domain|metastab|\\.sv |\\.vhd)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
