{
  "schema_version": "domain_pack.v1",
  "id": "hardware.signal-processing",
  "name": "Signal Processing & DSP",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "signal_processing",
    "dsp",
    "fft",
    "filter",
    "adc_dac"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.systems",
    "code.performance",
    "hardware.cpu-arch"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['signal_processing','dsp','fft','filter','adc_dac'].includes(d)) || profile.repo_signals.some(s=>/\\b(fft|dft|fir filter|iir filter|dsp|signal processing|nyquist|sample rate|spectral leak|convolution|adc|dac)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
