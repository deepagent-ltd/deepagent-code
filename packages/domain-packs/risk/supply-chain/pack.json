{
  "schema_version": "domain_pack.v1",
  "id": "risk.supply-chain",
  "name": "Supply Chain Risk",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "security",
    "supply_chain",
    "dependency"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production",
    "shell:run-install-script",
    "shell:run-postinstall",
    "shell:execute-untrusted-dependency",
    "shell:add-dependency-without-review"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.risk_markers.some(r=>['supply_chain','dependency','license'].includes(r)) || profile.repo_signals.some(s=>/\\b(lockfile|package install|postinstall|dependency|license|provenance)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
