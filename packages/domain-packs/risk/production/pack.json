{
  "schema_version": "domain_pack.v1",
  "id": "risk.production",
  "name": "Production Change Risk Controls",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "production",
    "deployment",
    "migration",
    "rollback",
    "incident"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.testing",
    "code.review",
    "code.release"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production",
    "shell:apply-production-migration",
    "shell:delete-production-data",
    "shell:disable-monitoring"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii",
      "secret_adjacent"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.task_kind === 'operate' || profile.risk_markers.some(r => ['production','deploy','deployment','incident','external_state'].includes(r)) || profile.repo_signals.some(s => /\\b(production|deploy|deployment|feature flag|traffic shift|incident|slo|canary|external state|production migration|apply production migration|production database migration|irreversible migration)\\b/i.test(s)) ? 0.93 : 0",
    "threshold": 0.5
  }
}
