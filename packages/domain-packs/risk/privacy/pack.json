{
  "schema_version": "domain_pack.v1",
  "id": "risk.privacy",
  "name": "Privacy Risk Controls",
  "version": "1.1.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "privacy",
    "pii",
    "phi",
    "pci",
    "data_minimization"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security",
    "code.review",
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production",
    "shell:exfiltrate",
    "shell:dump-personal-data",
    "shell:disable-redaction"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii",
      "secret_adjacent"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.risk_markers.some(r => ['privacy','pii','phi','pci','personal_data','gdpr','retention','redaction'].includes(r)) || profile.data_classes.some(d => ['pii','personal_data','phi','pci','sensitive_personal_data'].includes(d)) || profile.repo_signals.some(s => /\\b(pii|phi|pci|personal data|email|phone|ssn|consent|retention|redaction|delete request|data export)\\b/i.test(s)) ? 0.94 : 0",
    "threshold": 0.5
  }
}
