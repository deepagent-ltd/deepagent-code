{
  "schema_version": "domain_pack.v1",
  "id": "risk.license",
  "name": "Open-Source License & Attribution Risk",
  "description": "开源许可风险:协议合规、署名与 SPDX 标注",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "license",
    "oss_license",
    "attribution",
    "spdx"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.supply-chain",
    "code.review"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "legal_adjacent"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['license','oss_license','attribution','spdx'].includes(d)) || profile.repo_signals.some(s=>/\\b(license|spdx|gpl|apache.?2|mit license|copyleft|attribution|notice file|dependency license|redistribution)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
