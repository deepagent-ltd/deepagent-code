{
  "schema_version": "domain_pack.v1",
  "id": "code.database.mysql",
  "name": "MySQL / InnoDB Engine",
  "description": "MySQL:InnoDB 引擎、MariaDB 调优与运维",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "mysql",
    "innodb",
    "mariadb"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.sql",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['mysql','innodb','mariadb'].includes(d)) || profile.repo_signals.some(s=>/\\b(mysql|innodb|mariadb|my\\.cnf|mysqldump|gap lock|next.?key lock|mysql replication|binlog|utf8mb4)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
