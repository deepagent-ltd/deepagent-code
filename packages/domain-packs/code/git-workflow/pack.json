{
  "schema_version": "domain_pack.v1",
  "id": "code.git-workflow",
  "name": "Git Workflow",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "git_workflow",
    "branching",
    "merge",
    "rebase",
    "conflict"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.review"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['git_workflow','branching','merge','rebase','conflict'].includes(d)) || profile.repo_signals.some(s=>/\\b(git rebase|git merge|merge conflict|branch strategy|cherry.?pick|force push|git workflow|pull request|squash commit|detached head)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
