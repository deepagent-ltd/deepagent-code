{
  "schema_version": "domain_pack.v1",
  "id": "code.frontend.angular",
  "name": "Angular & RxJS Frontend",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "angular",
    "rxjs",
    "frontend"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.frontend.web",
    "code.typescript"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['angular','rxjs'].includes(d)) || profile.repo_signals.some(s=>/\\b(angular|ngmodule|rxjs|observable|@component|change detection|onpush|reactive forms|standalone component|@injectable)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
