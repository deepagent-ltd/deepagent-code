{
  "schema_version": "domain_pack.v1",
  "id": "code.frontend.react",
  "name": "React Frontend Engineering",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "react",
    "frontend",
    "typescript"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.typescript",
    "code.frontend.web"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.frameworks.includes('react') || profile.repo_signals.some(s=>/\\b(react|jsx|tsx|react hooks|next\\.js|react server component)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
