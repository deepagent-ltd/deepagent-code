{
  "schema_version": "domain_pack.v1",
  "id": "code.database.mongodb",
  "name": "MongoDB / Document Database",
  "description": "MongoDB:文档数据库、聚合查询与 BSON",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "mongodb",
    "document_db",
    "aggregation",
    "bson"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['mongodb','document_db','aggregation','bson'].includes(d)) || profile.repo_signals.some(s=>/\\b(mongodb|mongo|aggregation pipeline|bson|\\$lookup|\\$match|sharding key|replica set|document model|wiredtiger)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
