{
  "schema_version": "domain_pack.v1",
  "id": "code.fine-tuning",
  "name": "Fine-Tuning (LoRA, quantization, distillation, adapters)",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "fine_tuning",
    "lora",
    "qlora",
    "peft",
    "quantization",
    "distillation"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.ml-ai",
    "code.llm-app",
    "code.model-serving"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['fine_tuning','lora','qlora','peft','quantization','distillation'].includes(d)) || profile.repo_signals.some(s=>/\\b(lora|qlora|peft|fine.?tun|quantiz|bitsandbytes|int4|int8|distillat|rlhf|dpo|catastrophic forgetting|adapter)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
