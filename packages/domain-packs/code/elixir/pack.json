{
  "schema_version": "domain_pack.v1",
  "id": "code.elixir",
  "name": "Elixir, OTP & Phoenix",
  "description": "Elixir:OTP、Phoenix 与 BEAM 虚拟机",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "elixir",
    "otp",
    "phoenix",
    "beam"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.backend.service"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['elixir','otp','phoenix','beam'].includes(d)) || profile.repo_signals.some(s=>/\\b(elixir|mix\\.exs|genserver|otp supervis|phoenix|liveview|exunit|\\.ex |\\.exs|beam vm)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
