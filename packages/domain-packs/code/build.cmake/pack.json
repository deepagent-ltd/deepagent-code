{
  "schema_version": "domain_pack.v1",
  "id": "code.build.cmake",
  "name": "CMake Build System",
  "description": "CMake 构建:目标管理与 C/C++ 项目构建",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "cmake",
    "build_system",
    "cmake_targets"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.cpp",
    "code.c"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['cmake','cmake_targets'].includes(d)) || profile.repo_signals.some(s=>/\\b(cmakelists|cmake|target_link_libraries|add_library|find_package|cmake cache|ctest|cmake preset)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
