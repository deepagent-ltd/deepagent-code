{
  "schema_version": "domain_pack.v1",
  "id": "code.eval",
  "name": "LLM Evaluation & Regression Harnesses",
  "description": "LLM 评测:黄金集、回归测试与评判器",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "eval",
    "evaluation",
    "golden_data",
    "regression",
    "judge"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['eval','evaluation','golden_data','regression','judge'].includes(d)) || profile.repo_signals.some(s=>/\\b(eval(uation)? suite|golden (data|set)|llm.?as.?judge|benchmark regression|ablation|eval harness|metric selection|holdout)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
