{
  "schema_version": "domain_pack.v1",
  "id": "code.sql",
  "name": "SQL",
  "description": "SQL:查询编写、DDL/DML 与数据库操作",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "sql",
    "database"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.languages.includes('sql') || profile.repo_signals.some(s=>/\\b(\\.sql\\b|sql query|ddl|dml|sql migration|create table|alter table|join clause)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
