{
  "schema_version": "domain_pack.v1",
  "id": "code.mobile",
  "name": "Mobile Engineering",
  "description": "移动端开发:iOS 与 Android 应用工程",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "mobile",
    "ios",
    "android"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.testing",
    "risk.privacy"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.platforms.includes('mobile') || profile.repo_signals.some(s=>/\\b(iOS|Android|SwiftUI|Compose|mobile|app store|play store)\\b/i.test(s)) ? 0.84 : 0",
    "threshold": 0.5
  }
}
