{
  "schema_version": "domain_pack.v1",
  "id": "code.ml-ai",
  "name": "Machine Learning Engineering (training, inference, datasets)",
  "description": "机器学习工程:模型训练、推理与数据集处理",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "ml",
    "training",
    "inference",
    "datasets"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.python",
    "code.testing",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['ml','training','inference','datasets'].includes(d)) || profile.repo_signals.some(s=>/\\b(training loop|overfitting|train.?test split|data leakage|loss function|gradient|epoch|hyperparameter|pytorch|tensorflow|model checkpoint)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
