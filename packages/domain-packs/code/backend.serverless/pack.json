{
  "schema_version": "domain_pack.v1",
  "id": "code.backend.serverless",
  "name": "Serverless & Function-as-a-Service",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "serverless",
    "lambda",
    "faas",
    "functions"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "platform.cloud",
    "code.observability"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['serverless','lambda','faas','functions'].includes(d)) || profile.repo_signals.some(s=>/\\b(serverless|aws lambda|cloud function|faas|cold start|api gateway|lambda function|function timeout|event trigger|step function)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
