{
  "schema_version": "domain_pack.v1",
  "id": "code.r",
  "name": "R Language and Tidyverse",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "r_lang",
    "rstats",
    "tidyverse",
    "r_packages"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.data-quality"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['r_lang','rstats','tidyverse','r_packages'].includes(d)) || profile.repo_signals.some(s=>/\\b(\\br language\\b|rstudio|tidyverse|ggplot2|dplyr|\\.rmd|r package|cran|data\\.frame|r script)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
