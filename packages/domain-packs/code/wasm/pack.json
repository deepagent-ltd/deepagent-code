{
  "schema_version": "domain_pack.v1",
  "id": "code.wasm",
  "name": "WebAssembly: Build, Interop & Runtimes",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "wasm",
    "webassembly",
    "abi",
    "browser_runtime"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.rust",
    "platform.web"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['wasm','webassembly','abi','browser_runtime'].includes(d)) || profile.repo_signals.some(s=>/\\b(wasm|webassembly|wasm-bindgen|wasi|emscripten|wasm-pack|linear memory|wasm module)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
