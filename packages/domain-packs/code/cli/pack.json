{
  "schema_version": "domain_pack.v1",
  "id": "code.cli",
  "name": "Command-Line Interface Engineering",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "cli",
    "command_line",
    "tty",
    "terminal"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['cli','command_line','tty','terminal'].includes(d)) || profile.repo_signals.some(s=>/\\b(command.?line|cli tool|argument parsing|exit code|stdin|stdout|subcommand|flag parsing|tty|argv|getopt)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
