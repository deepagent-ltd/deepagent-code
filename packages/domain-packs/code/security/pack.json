{
  "schema_version": "domain_pack.v1",
  "id": "code.security",
  "name": "Code Secure Coding",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "security",
    "code"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security",
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.risk_markers.includes('security') || profile.code_domains.includes('security') ? 0.82 : 0",
    "threshold": 0.5
  }
}
