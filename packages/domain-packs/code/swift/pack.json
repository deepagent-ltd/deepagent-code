{
  "schema_version": "domain_pack.v1",
  "id": "code.swift",
  "name": "Swift",
  "description": "Swift 开发:语言特性、SwiftUI 与苹果生态",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "swift",
    "code",
    "mobile"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.languages.includes('swift') || profile.repo_signals.some(s=>/\\b(Package.swift|SwiftUI|Xcode|.swift)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
