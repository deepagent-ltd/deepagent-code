{
  "schema_version": "domain_pack.v1",
  "id": "code.caching",
  "name": "Caching Patterns",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "caching",
    "cache_invalidation",
    "cache_layer",
    "cdn_cache"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database.redis",
    "code.performance",
    "code.backend.service"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['caching','cache_invalidation','cache_layer','cdn_cache'].includes(d)) || profile.repo_signals.some(s=>/\\b(cache invalidation|cache.?aside|write.?through|write.?behind|cache stampede|thundering herd|stale.?while.?revalidate|cache key|ttl strategy|cache coherence)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
