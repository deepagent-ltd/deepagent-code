{
  "schema_version": "domain_pack.v1",
  "id": "code.database.timeseries",
  "name": "Time-Series Databases",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "timeseries_db",
    "influxdb",
    "timescaledb",
    "prometheus_tsdb"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.observability"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['timeseries_db','influxdb','timescaledb','prometheus_tsdb'].includes(d)) || profile.repo_signals.some(s=>/\\b(time.?series database|influxdb|timescaledb|hypertable|downsampl|retention policy|continuous aggregate|line protocol|cardinality explosion)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
