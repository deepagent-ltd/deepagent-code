{
  "schema_version": "domain_pack.v1",
  "id": "code.benchmarking",
  "name": "Benchmarking",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "code",
    "benchmarking",
    "performance"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.includes('benchmarking') || profile.repo_signals.some(s=>/\\b(benchmark|bench|baseline|regression threshold|perf test)\\b/i.test(s)) ? 0.88 : 0",
    "threshold": 0.5
  }
}
