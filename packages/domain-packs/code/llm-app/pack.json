{
  "schema_version": "domain_pack.v1",
  "id": "code.llm-app",
  "name": "LLM Application Engineering",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "llm_app",
    "llm",
    "model_api",
    "tool_calls",
    "structured_output"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "code.testing",
    "risk.privacy"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['llm_app','llm','model_api','tool_calls','structured_output'].includes(d)) || profile.repo_signals.some(s=>/\\b(llm|language model|model api|tool call|function call|structured output|prompt injection|token limit|completion api|openai|anthropic)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
