{
  "schema_version": "domain_pack.v1",
  "id": "code.search",
  "name": "Search Engineering (inverted index, ranking, Elasticsearch)",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "search",
    "elasticsearch",
    "ranking",
    "indexing"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.backend.api",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['search','elasticsearch','ranking','indexing'].includes(d)) || profile.repo_signals.some(s=>/\\b(elasticsearch|opensearch|inverted index|bm25|relevance ranking|full.?text search|analyzer|query dsl|faceting|search index)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
