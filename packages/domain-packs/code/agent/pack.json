{
  "schema_version": "domain_pack.v1",
  "id": "code.agent",
  "name": "Agent Loop & Tool Orchestration",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "agent",
    "agent_loop",
    "tool_registry",
    "memory",
    "mcp"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.llm-app",
    "code.testing",
    "risk.privacy"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['agent','agent_loop','tool_registry','memory','mcp'].includes(d)) || profile.repo_signals.some(s=>/\\b(agent loop|tool registry|agent memory|context window|mcp server|react agent|multi.?step agent|tool permission|no.?progress)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
