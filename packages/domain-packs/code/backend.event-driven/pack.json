{
  "schema_version": "domain_pack.v1",
  "id": "code.backend.event-driven",
  "name": "Event-Driven & Messaging Systems",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "event_driven",
    "events",
    "messaging",
    "outbox",
    "streaming"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.service",
    "code.database",
    "code.observability"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['event_driven','events','messaging','outbox','streaming'].includes(d)) || profile.repo_signals.some(s=>/\\b(event bus|message queue|outbox|consumer|kafka|sqs|rabbitmq|dead.?letter|event sourcing|idempotent consumer)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
