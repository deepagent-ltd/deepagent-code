{
  "schema_version": "domain_pack.v1",
  "id": "code.cryptography",
  "name": "Applied Cryptography (Defensive Use of Primitives)",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "cryptography",
    "encryption",
    "hashing",
    "key_management"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security",
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['cryptography','encryption','hashing','key_management'].includes(d)) || profile.repo_signals.some(s=>/\\b(encryption|aes|aead|hashing|sha-256|bcrypt|key management|cryptograph|nonce|constant.?time|digital signature|kdf)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
