{
  "schema_version": "domain_pack.v1",
  "id": "code.javascript",
  "name": "JavaScript Runtime and Tooling",
  "description": "JavaScript:Node、浏览器运行时与工具链",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "code",
    "javascript",
    "node",
    "browser",
    "runtime",
    "tooling"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "validation",
    "diagnosis"
  ],
  "depends_on": [
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "edit",
    "shell:test",
    "shell:node",
    "shell:package-manager"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.languages.includes('javascript') || profile.repo_signals.some((s) => ['package.json','package-lock.json','pnpm-lock.yaml','yarn.lock','bun.lock','vite.config.js','webpack.config.js','rollup.config.js'].includes(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
