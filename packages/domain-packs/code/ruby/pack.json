{
  "schema_version": "domain_pack.v1",
  "id": "code.ruby",
  "name": "Ruby, Bundler & Rails",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "ruby",
    "rails",
    "bundler"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.backend.api"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['ruby','rails','bundler'].includes(d)) || profile.repo_signals.some(s=>/\\b(ruby|gemfile|bundler|rspec|rails|activerecord|\\.rb|rake task|gem install)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
