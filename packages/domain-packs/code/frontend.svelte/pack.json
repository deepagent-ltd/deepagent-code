{
  "schema_version": "domain_pack.v1",
  "id": "code.frontend.svelte",
  "name": "Svelte & SvelteKit Frontend",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "svelte",
    "sveltekit",
    "frontend"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.frontend.web",
    "code.javascript",
    "code.typescript"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['svelte','sveltekit'].includes(d)) || profile.repo_signals.some(s=>/\\b(svelte|sveltekit|svelte store|\\$:|svelte component|\\.svelte|runes|load function)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
