{
  "schema_version": "domain_pack.v1",
  "id": "code.database.redis",
  "name": "Redis Engineering",
  "description": "Redis:缓存、键值存储与过期策略",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "redis",
    "cache",
    "keyvalue",
    "ttl"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.backend.service"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['redis','keyvalue'].includes(d)) || profile.repo_signals.some(s=>/\\b(redis|cache invalidation|ttl|eviction|redlock|redis stream|setex|expire key|lpush)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
