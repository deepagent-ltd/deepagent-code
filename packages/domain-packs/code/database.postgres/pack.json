{
  "schema_version": "domain_pack.v1",
  "id": "code.database.postgres",
  "name": "PostgreSQL Engineering",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "postgres",
    "postgresql",
    "database",
    "sql"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.database",
    "code.sql",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['postgres','postgresql'].includes(d)) || profile.repo_signals.some(s=>/\\b(postgres|postgresql|psql|pg_|jsonb|pg_stat|explain analyze|vacuum|gin index|gist)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
