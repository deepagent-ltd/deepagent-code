{
  "schema_version": "domain_pack.v1",
  "id": "code.embedded",
  "name": "Embedded Firmware and Real-Time Systems",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "embedded",
    "firmware",
    "rtos",
    "mcu",
    "bare_metal"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.c",
    "code.systems"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['embedded','firmware','rtos','mcu','bare_metal'].includes(d)) || profile.repo_signals.some(s=>/\\b(firmware|rtos|freertos|microcontroller|mcu|bare.?metal|interrupt service|isr|register map|watchdog|embedded)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
