{
  "schema_version": "domain_pack.v1",
  "id": "code.api-design",
  "name": "API Design",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "api_design",
    "contract_design",
    "versioning_design",
    "resource_modeling"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "code.sdk"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['api_design','contract_design','versioning_design','resource_modeling'].includes(d)) || profile.repo_signals.some(s=>/\\b(api design|resource modeling|api versioning strategy|pagination design|idempotency design|hateoas|api style guide|contract.?first)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
