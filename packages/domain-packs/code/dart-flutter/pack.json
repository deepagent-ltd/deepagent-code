{
  "schema_version": "domain_pack.v1",
  "id": "code.dart-flutter",
  "name": "Dart & Flutter",
  "description": "Dart 与 Flutter:跨平台移动端 UI 开发",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "dart",
    "flutter",
    "mobile"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.mobile"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['dart','flutter','mobile'].includes(d)) || profile.repo_signals.some(s=>/\\b(dart|flutter|pubspec\\.yaml|widget build|setstate|flutter build|platform channel|\\.dart|stateful widget)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
