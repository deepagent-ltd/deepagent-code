{
  "schema_version": "domain_pack.v1",
  "id": "code.backend.realtime",
  "name": "Realtime Connections & Pub/Sub",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "realtime",
    "websocket",
    "sse",
    "pubsub",
    "subscriptions"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "code.networking",
    "code.frontend.web"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['realtime','websocket','sse','pubsub','subscriptions'].includes(d)) || profile.repo_signals.some(s=>/\\b(websocket|ws connection|server.?sent event|sse|pub.?sub|live update|realtime|subscription channel)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
