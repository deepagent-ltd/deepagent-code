{
  "schema_version": "domain_pack.v1",
  "id": "code.docs",
  "name": "Code Documentation",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "code",
    "docs"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.task_kind === 'explain' || profile.code_domains.includes('docs') || profile.repo_signals.some(s=>/\\b(readme|docs|changelog|adr|diagram|onboarding)\\b/i.test(s)) ? 0.82 : 0",
    "threshold": 0.5
  }
}
