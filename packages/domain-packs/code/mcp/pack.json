{
  "schema_version": "domain_pack.v1",
  "id": "code.mcp",
  "name": "MCP Integration",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "code",
    "mcp",
    "tooling"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "risk.security"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.includes('mcp') || profile.repo_signals.some(s=>/\\b(mcp|model context protocol|tool server|tool call|tool schema|capability negotiation)\\b/i.test(s)) ? 0.88 : 0",
    "threshold": 0.5
  }
}
