{
  "schema_version": "domain_pack.v1",
  "id": "code.rust",
  "name": "Rust",
  "description": "Rust 开发:所有权、并发安全、Cargo 与系统级编程",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "rust",
    "code"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.languages.includes('rust') || profile.repo_signals.some(s=>/\\b(Cargo.toml|cargo test|borrow checker|.rs)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
