{
  "schema_version": "domain_pack.v1",
  "id": "code.kotlin",
  "name": "Kotlin Engineering",
  "description": "Kotlin 开发:JVM、Gradle 与 Android",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "code",
    "kotlin",
    "jvm",
    "gradle",
    "android"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "validation",
    "diagnosis"
  ],
  "depends_on": [
    "code.core",
    "code.java-jvm"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "edit",
    "shell:gradle",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.languages.includes('kotlin') || profile.repo_signals.some((s) => ['build.gradle.kts','settings.gradle.kts','gradlew','gradlew.bat'].includes(s)) || profile.frameworks.includes('android') ? 0.86 : 0",
    "threshold": 0.5
  }
}
