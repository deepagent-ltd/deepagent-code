{
  "schema_version": "domain_pack.v1",
  "id": "code.build.bazel",
  "name": "Bazel Build System",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "bazel",
    "build_graph",
    "hermetic_build",
    "remote_cache"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.core",
    "code.performance"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['bazel','build_graph','hermetic_build','remote_cache'].includes(d)) || profile.repo_signals.some(s=>/\\b(bazel|\\bbuild\\b file|starlark|bazel target|hermetic build|remote cache|bazel query|\\bwORKSPACE\\b|bzlmod)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
