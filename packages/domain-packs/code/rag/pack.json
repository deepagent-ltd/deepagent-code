{
  "schema_version": "domain_pack.v1",
  "id": "code.rag",
  "name": "Retrieval-Augmented Generation",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "rag",
    "retrieval",
    "chunking",
    "rerank",
    "grounding"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.llm-app",
    "code.search",
    "code.eval"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['rag','retrieval','chunking','rerank','grounding'].includes(d)) || profile.repo_signals.some(s=>/\\b(rag|retrieval augmented|chunking|embedding|rerank|vector (search|index|store)|grounding|citation|semantic search)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
