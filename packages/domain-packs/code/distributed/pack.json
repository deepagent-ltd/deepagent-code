{
  "schema_version": "domain_pack.v1",
  "id": "code.distributed",
  "name": "Distributed Systems (Consensus, Replication, Consistency)",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "distributed",
    "consensus",
    "replication",
    "consistency"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.service",
    "code.networking",
    "code.observability"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['distributed','consensus','replication','consistency'].includes(d)) || profile.repo_signals.some(s=>/\\b(distributed system|consensus|raft|paxos|replication|quorum|split.?brain|leader election|eventual consistency|cap theorem|vector clock)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
