{
  "schema_version": "domain_pack.v1",
  "id": "code.sdk",
  "name": "SDK Engineering",
  "description": "SDK 工程:客户端生成、接口设计与版本兼容",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "sdk",
    "api",
    "code"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.backend.api",
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.includes('sdk') || profile.repo_signals.some(s=>/\\b(sdk|client generation|openapi|generated client|semver)\\b/i.test(s)) ? 0.84 : 0",
    "threshold": 0.5
  }
}
