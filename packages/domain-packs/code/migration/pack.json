{
  "schema_version": "domain_pack.v1",
  "id": "code.migration",
  "name": "Code Migration",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "code",
    "migration"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.task_kind === 'migrate' || profile.code_domains.includes('migration') || profile.repo_signals.some(s=>/\\b(migrate|codemod|compat(ibility)? (shim|layer|window)|deprecat|version bump|upgrade (the )?(dependency|dependencies|version|package|library|framework|runtime|schema|node|react|api)|breaking change)\\b/i.test(s)) ? 0.88 : 0",
    "threshold": 0.5
  }
}
