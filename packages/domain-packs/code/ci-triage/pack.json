{
  "schema_version": "domain_pack.v1",
  "id": "code.ci-triage",
  "name": "CI Triage",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "code",
    "ci_triage",
    "validation"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.testing"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.task_kind === 'test' && profile.repo_signals.some(s=>/\\b(ci|workflow|actions|pipeline|failed check)\\b/i.test(s)) || profile.code_domains.includes('ci_triage') ? 0.9 : 0",
    "threshold": 0.5
  }
}
