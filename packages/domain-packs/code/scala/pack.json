{
  "schema_version": "domain_pack.v1",
  "id": "code.scala",
  "name": "Scala, sbt & the JVM",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "scala",
    "sbt",
    "jvm"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.java-jvm",
    "code.core"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['scala','sbt','jvm'].includes(d)) || profile.repo_signals.some(s=>/\\b(scala|sbt|build\\.sbt|implicit|pattern match|case class|akka|cats effect|\\.scala)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
