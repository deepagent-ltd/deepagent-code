{
  "schema_version": "domain_pack.v1",
  "id": "code.mobile.android",
  "name": "Android App Development (Jetpack Compose/Kotlin)",
  "description": "安卓开发:Jetpack Compose、Kotlin 与应用生命周期",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "android",
    "jetpack_compose",
    "kotlin_android"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.kotlin",
    "risk.privacy"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['android','jetpack_compose','kotlin_android'].includes(d)) || profile.repo_signals.some(s=>/\\b(android|jetpack compose|activity lifecycle|fragment|viewmodel|workmanager|androidmanifest|gradle android|recyclerview|\\.apk)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
