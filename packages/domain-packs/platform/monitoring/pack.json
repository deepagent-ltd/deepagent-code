{
  "schema_version": "domain_pack.v1",
  "id": "platform.monitoring",
  "name": "Prometheus and Grafana Monitoring",
  "description": "监控告警:Prometheus、Grafana、PromQL 与 SLO",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "monitoring",
    "prometheus",
    "grafana",
    "alerting",
    "sli_slo"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.observability",
    "platform.kubernetes"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['monitoring','prometheus','grafana','alerting','sli_slo'].includes(d)) || profile.repo_signals.some(s=>/\\b(prometheus|grafana|promql|alertmanager|alert rule|recording rule|\\bslo\\b|\\bsli\\b|error budget|scrape config)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
