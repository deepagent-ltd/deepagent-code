{
  "schema_version": "domain_pack.v1",
  "id": "platform.cloud.aws",
  "name": "AWS Cloud Platform",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "aws",
    "iam",
    "lambda_aws",
    "ecs",
    "cloudwatch"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "platform.cloud",
    "risk.security",
    "risk.production"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['aws','iam','lambda_aws','ecs','cloudwatch'].includes(d)) || profile.repo_signals.some(s=>/\\b(\\baws\\b|iam policy|aws lambda|\\becs\\b|\\beks\\b|cloudwatch|s3 bucket|dynamodb|aws sdk|boto3|cloudformation)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
