{
  "schema_version": "domain_pack.v1",
  "id": "platform.service-mesh",
  "name": "Service Mesh",
  "description": "服务网格:Istio/Linkerd 的流量治理、mTLS 与边车",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "service_mesh",
    "istio",
    "linkerd",
    "traffic_policy",
    "sidecar"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "platform.kubernetes",
    "code.networking",
    "code.observability"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['service_mesh','istio','linkerd','traffic_policy','sidecar'].includes(d)) || profile.repo_signals.some(s=>/\\b(service mesh|istio|linkerd|envoy proxy|sidecar|virtualservice|destinationrule|mtls|traffic split|circuit break)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
