{
  "schema_version": "domain_pack.v1",
  "id": "platform.docker",
  "name": "Docker Platform",
  "description": "Docker 容器:镜像构建、多阶段编译与 Compose 编排",
  "version": "1.0.0",
  "scope": "system",
  "risk": "medium",
  "domains": [
    "platform",
    "docker",
    "container"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.platforms.includes('docker') || profile.repo_signals.some(s=>/\\b(Dockerfile|docker compose|container|image|multi-stage)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
