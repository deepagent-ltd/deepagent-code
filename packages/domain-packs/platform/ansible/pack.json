{
  "schema_version": "domain_pack.v1",
  "id": "platform.ansible",
  "name": "Ansible Configuration Management",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "ansible",
    "config_management",
    "playbook",
    "idempotent_provisioning"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "platform.cloud",
    "code.systems"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['ansible','config_management','playbook','idempotent_provisioning'].includes(d)) || profile.repo_signals.some(s=>/\\b(ansible|playbook|ansible role|inventory file|ansible vault|idempotent task|handlers notify|ansible module|gather_facts)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
