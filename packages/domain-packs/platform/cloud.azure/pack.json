{
  "schema_version": "domain_pack.v1",
  "id": "platform.cloud.azure",
  "name": "Microsoft Azure Platform",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "azure",
    "aks",
    "azure_functions",
    "azure_ad"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "platform.cloud",
    "risk.security",
    "risk.production"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.code_domains.some(d=>['azure','aks','azure_functions','azure_ad'].includes(d)) || profile.repo_signals.some(s=>/\\b(azure|\\baks\\b|azure functions|azure ad|entra id|managed identity|azure blob|arm template|bicep|app service)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
