{
  "schema_version": "domain_pack.v1",
  "id": "platform.cloud",
  "name": "Cloud Platform",
  "description": "云平台通用:多云环境、资源管理与基础设施开发",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "platform",
    "cloud",
    "environment"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security",
    "code.environment"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.platforms.includes('cloud') || profile.repo_signals.some(s=>/\\b(azure|aws|gcp|iam|cloud|resource group|terraform|bicep)\\b/i.test(s)) ? 0.86 : 0",
    "threshold": 0.5
  }
}
