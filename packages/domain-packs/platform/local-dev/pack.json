{
  "schema_version": "domain_pack.v1",
  "id": "platform.local-dev",
  "name": "Local Development Platform",
  "version": "1.0.0",
  "scope": "system",
  "risk": "low",
  "domains": [
    "platform",
    "local_dev",
    "environment"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "code.environment"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.platforms.includes('local') || profile.repo_signals.some(s=>/\\b(local dev|dev server|localhost|hot reload|watch mode|bootstrap the (project|repo|workspace)|local setup script)\\b/i.test(s)) ? 0.82 : 0",
    "threshold": 0.5
  }
}
