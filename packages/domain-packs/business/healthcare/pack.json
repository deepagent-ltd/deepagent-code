{
  "schema_version": "domain_pack.v1",
  "id": "business.healthcare",
  "name": "Business Healthcare Engineering",
  "description": "医疗业务:患者数据、PHI 与合规隐私场景开发",
  "version": "1.0.0",
  "scope": "system",
  "risk": "regulated",
  "domains": [
    "healthcare",
    "business",
    "privacy"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.privacy",
    "risk.security"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii",
      "phi"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.business_domains.includes('healthcare') || profile.repo_signals.some(s=>/\\b(patient|clinical|healthcare|PHI|HIPAA|medical)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
