{
  "schema_version": "domain_pack.v1",
  "id": "business.finance",
  "name": "Business Finance Engineering",
  "description": "金融业务:支付、账本、对账与风控相关开发",
  "version": "1.0.0",
  "scope": "system",
  "risk": "high",
  "domains": [
    "finance",
    "business",
    "risk"
  ],
  "provides": [
    "knowledge",
    "strategy",
    "methodology",
    "skill",
    "diagnosis",
    "validation"
  ],
  "depends_on": [
    "risk.security",
    "risk.privacy"
  ],
  "conflicts_with": [],
  "knowledge_store": "document_store",
  "allowed_tools": [
    "read",
    "shell:test"
  ],
  "denied_tools": [
    "shell:deploy-production"
  ],
  "data_policy": {
    "sensitivity": [
      "source_code",
      "user_data",
      "pii"
    ],
    "default_admission": "summary_only",
    "secret_policy": "deny"
  },
  "detector": {
    "inline": "profile.business_domains.includes('finance') || profile.repo_signals.some(s=>/\\b(payment|ledger|invoice|trade|financial|money|billing)\\b/i.test(s)) ? 0.9 : 0",
    "threshold": 0.5
  }
}
